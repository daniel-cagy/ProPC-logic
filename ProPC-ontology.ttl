@prefix : <http://www.semanticweb.org/danielcagy/ontologies/2026/6/ProPC-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/danielcagy/ontologies/2026/6/ProPC-ontology> .

<http://www.semanticweb.org/danielcagy/ontologies/2026/6/ProPC-ontology> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://example.org/univ#belongsToFamily
<http://example.org/univ#belongsToFamily> rdf:type owl:ObjectProperty ;
                                          rdfs:domain <http://example.org/univ#CPU> ,
                                                      <http://example.org/univ#Component> ;
                                          rdfs:range <http://example.org/univ#CPUFamily> .


###  http://example.org/univ#compatibleWith
<http://example.org/univ#compatibleWith> rdf:type owl:ObjectProperty ;
                                         owl:inverseOf <http://example.org/univ#compatibleWith> ;
                                         rdf:type owl:SymmetricProperty .


###  http://example.org/univ#hasCertification
<http://example.org/univ#hasCertification> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <http://example.org/univ#Component> ,
                                                       <http://example.org/univ#PSU> ;
                                           rdfs:range <http://example.org/univ#Certification> .


###  http://example.org/univ#hasPowerFactor
<http://example.org/univ#hasPowerFactor> rdf:type owl:ObjectProperty ;
                                         rdfs:domain <http://example.org/univ#CPU> ,
                                                     <http://example.org/univ#Component> ,
                                                     <http://example.org/univ#PSU> ;
                                         rdfs:range <http://example.org/univ#CPUFamily> .


###  http://example.org/univ#hasSocket
<http://example.org/univ#hasSocket> rdf:type owl:ObjectProperty ;
                                    rdfs:domain <http://example.org/univ#Component> ,
                                                <http://example.org/univ#Motherboard> ;
                                    rdfs:range <http://example.org/univ#Socket> .


###  http://example.org/univ#hasTier
<http://example.org/univ#hasTier> rdf:type owl:ObjectProperty ;
                                  rdfs:domain <http://example.org/univ#Component> ;
                                  rdfs:range <http://example.org/univ#Tier> .


###  http://example.org/univ#manufactures
<http://example.org/univ#manufactures> rdf:type owl:ObjectProperty ;
                                       rdfs:domain <http://example.org/univ#Manufacturer> ;
                                       rdfs:range <http://example.org/univ#Component> .


###  http://example.org/univ#manufacturesFamily
<http://example.org/univ#manufacturesFamily> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <http://example.org/univ#Manufacturer> ;
                                             rdfs:range <http://example.org/univ#CPUFamily> .


###  http://example.org/univ#usesSocket
<http://example.org/univ#usesSocket> rdf:type owl:ObjectProperty ;
                                     rdfs:domain <http://example.org/univ#CPU> ,
                                                 <http://example.org/univ#Component> ;
                                     rdfs:range <http://example.org/univ#Socket> .


#################################################################
#    Data properties
#################################################################

###  http://example.org/univ#hasBaseClock
<http://example.org/univ#hasBaseClock> rdf:type owl:DatatypeProperty ;
                                       rdfs:domain <http://example.org/univ#CPU> ,
                                                   <http://example.org/univ#Component> ;
                                       rdfs:range xsd:decimal .


###  http://example.org/univ#hasBoostClock
<http://example.org/univ#hasBoostClock> rdf:type owl:DatatypeProperty ;
                                        rdfs:domain <http://example.org/univ#CPU> ,
                                                    <http://example.org/univ#Component> ;
                                        rdfs:range xsd:decimal .


###  http://example.org/univ#hasCores
<http://example.org/univ#hasCores> rdf:type owl:DatatypeProperty ;
                                   rdfs:domain <http://example.org/univ#CPU> ,
                                               <http://example.org/univ#Component> ;
                                   rdfs:range xsd:integer .


###  http://example.org/univ#hasFormFactor
<http://example.org/univ#hasFormFactor> rdf:type owl:DatatypeProperty ;
                                        rdfs:domain <http://example.org/univ#Component> ,
                                                    <http://example.org/univ#Motherboard> ;
                                        rdfs:range xsd:string .


###  http://example.org/univ#hasIntegratedGraphics
<http://example.org/univ#hasIntegratedGraphics> rdf:type owl:DatatypeProperty ;
                                                rdfs:domain <http://example.org/univ#CPU> ,
                                                            <http://example.org/univ#Component> ;
                                                rdfs:range xsd:boolean .


###  http://example.org/univ#hasM2Slots
<http://example.org/univ#hasM2Slots> rdf:type owl:DatatypeProperty ;
                                     rdfs:domain <http://example.org/univ#Component> ,
                                                 <http://example.org/univ#Motherboard> ;
                                     rdfs:range xsd:string .


###  http://example.org/univ#hasMaxPower
<http://example.org/univ#hasMaxPower> rdf:type owl:DatatypeProperty ;
                                      rdfs:domain <http://example.org/univ#Component> ;
                                      rdfs:range xsd:integer .


###  http://example.org/univ#hasPCIeSlots
<http://example.org/univ#hasPCIeSlots> rdf:type owl:DatatypeProperty ;
                                       rdfs:domain <http://example.org/univ#Component> ,
                                                   <http://example.org/univ#Motherboard> ;
                                       rdfs:range xsd:string .


###  http://example.org/univ#hasPower
<http://example.org/univ#hasPower> rdf:type owl:DatatypeProperty ;
                                   rdfs:domain <http://example.org/univ#Component> ,
                                               <http://example.org/univ#PSU> ;
                                   rdfs:range xsd:integer .


###  http://example.org/univ#hasPowerFactor
<http://example.org/univ#hasPowerFactor> rdf:type owl:DatatypeProperty ;
                                         rdfs:range xsd:decimal .


###  http://example.org/univ#hasRAMArchitecture
<http://example.org/univ#hasRAMArchitecture> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain <http://example.org/univ#Component> ,
                                                         <http://example.org/univ#Motherboard> ;
                                             rdfs:range xsd:string .


###  http://example.org/univ#hasRAMSlots
<http://example.org/univ#hasRAMSlots> rdf:type owl:DatatypeProperty ;
                                      rdfs:domain <http://example.org/univ#Component> ,
                                                  <http://example.org/univ#Motherboard> ;
                                      rdfs:range xsd:integer .


###  http://example.org/univ#hasSATAPorts
<http://example.org/univ#hasSATAPorts> rdf:type owl:DatatypeProperty ;
                                       rdfs:domain <http://example.org/univ#Component> ,
                                                   <http://example.org/univ#Motherboard> ;
                                       rdfs:range xsd:integer .


###  http://example.org/univ#hasTDP
<http://example.org/univ#hasTDP> rdf:type owl:DatatypeProperty ;
                                 rdfs:domain <http://example.org/univ#Component> ;
                                 rdfs:range xsd:integer .


###  http://example.org/univ#hasThreads
<http://example.org/univ#hasThreads> rdf:type owl:DatatypeProperty ;
                                     rdfs:domain <http://example.org/univ#CPU> ,
                                                 <http://example.org/univ#Component> ;
                                     rdfs:range xsd:integer .


#################################################################
#    Classes
#################################################################

###  http://example.org/univ#CPU
<http://example.org/univ#CPU> rdf:type owl:Class ;
                              rdfs:subClassOf <http://example.org/univ#Component> .


###  http://example.org/univ#CPUFamily
<http://example.org/univ#CPUFamily> rdf:type owl:Class .


###  http://example.org/univ#Certification
<http://example.org/univ#Certification> rdf:type owl:Class .


###  http://example.org/univ#Component
<http://example.org/univ#Component> rdf:type owl:Class .


###  http://example.org/univ#Manufacturer
<http://example.org/univ#Manufacturer> rdf:type owl:Class .


###  http://example.org/univ#Motherboard
<http://example.org/univ#Motherboard> rdf:type owl:Class ;
                                      rdfs:subClassOf <http://example.org/univ#Component> .


###  http://example.org/univ#PSU
<http://example.org/univ#PSU> rdf:type owl:Class ;
                              rdfs:subClassOf <http://example.org/univ#Component> .


###  http://example.org/univ#Socket
<http://example.org/univ#Socket> rdf:type owl:Class .


###  http://example.org/univ#Tier
<http://example.org/univ#Tier> rdf:type owl:Class .


