ex:B650M_PLUS a ex:Motherboard ;
    ex:hasSocket ex:AM5 ;
    ex:hasTier ex:MidRange .
ex:Asus ex:manufactures ex:B650M_PLUS .

ex:X670E_PROART a ex:Motherboard ;
    ex:hasSocket ex:AM5 ;
    ex:hasTier ex:Premium .
ex:Asus ex:manufactures ex:X670E_PROART .

ex:B650M_AORUS_ELITE a ex:Motherboard ;
    ex:hasSocket ex:AM5 ;
    ex:hasTier ex:MidRange .
