@prefix ex: <http://example.org/univ#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Component a owl:Class .
ex:Manufacturer a owl:Class .
ex:Tier a owl:Class .
ex:Socket a owl:Class .

ex:CPU a owl:Class ;
    rdfs:subClassOf ex:Component .

ex:Motherboard a owl:Class ;
    rdfs:subClassOf ex:Component .

ex:usesSocket a owl:ObjectProperty ;
    rdfs:domain ex:CPU ;
    rdfs:range ex:Socket .

ex:hasSocket a owl:ObjectProperty ;
    rdfs:domain ex:Motherboard ;
    rdfs:range ex:Socket .

ex:manufactures a owl:ObjectProperty ;
    rdfs:domain ex:Manufacturer ;
    rdfs:range ex:Component .

ex:hasTier a owl:ObjectProperty ;
    rdfs:domain ex:Component ;
    rdfs:range ex:Tier .

ex:hasCores a owl:DatatypeProperty ;
    rdfs:domain ex:CPU ;
    rdfs:range xsd:integer .

ex:hasThreads a owl:DatatypeProperty ;
    rdfs:domain ex:CPU ;
    rdfs:range xsd:integer .

ex:hasTDP a owl:DatatypeProperty ;
    rdfs:domain ex:CPU ;
    rdfs:range xsd:integer .

ex:hasIntegratedGraphics a owl:DatatypeProperty ;
    rdfs:domain ex:CPU ;
    rdfs:range xsd:boolean ;

ex:isVariantOf a owl:ObjectProperty ;
    rdfs:domain ex:CPU ;
    rdfs:range ex:CPU .

ex:Intel a ex:Manufacturer .
ex:AMD a ex:Manufacturer .
ex:Asus a ex:Manufacturer .
ex:Gigabyte a ex:Manufacturer .
ex:MSI a ex:Manufacturer .

ex:AM5 a ex:Socket .
ex:LGA1700 a ex:Socket .

ex:EntryLevel a ex:Tier .
ex:MidRange a ex:Tier .
ex:Advanced a ex:Tier .
ex:Premium a ex:Tier .

ex:core_14100 a ex:CPU ;
    ex:usesSocket ex:LGA1700 ;
    ex:hasTier ex:EntryLevel ;
    ex:hasCores 4 ;
    ex:hasThreads 8 .

ex:core_14600k a ex:CPU ;
    ex:usesSocket ex:LGA1700 ;
    ex:hasTier ex:MidRange ;
    ex:hasCores 14 ;
    ex:hasThreads 20 .

ex:core_14700k a ex:CPU ;
    ex:usesSocket ex:LGA1700 ;
    ex:hasTier ex:Advanced ;
    ex:hasCores 20 ;
    ex:hasThreads 28 .

ex:core_14900k a ex:CPU ;
    ex:usesSocket ex:LGA1700 ;
    ex:hasTier ex:Premium ;
    ex:hasCores 24 ;
    ex:hasThreads 32 .

ex:ryzen_7300x a ex:CPU ;
    ex:usesSocket ex:AM5 ;
    ex:hasTier ex:EntryLevel ;
    ex:hasCores 4 ;
    ex:hasThreads 8 .

ex:ryzen_7600x a ex:CPU ;
    ex:usesSocket ex:AM5 ;
    ex:hasTier ex:MidRange ;
    ex:hasCores 6 ;
    ex:hasThreads 12 .

ex:ryzen_7700x a ex:CPU ;
    ex:usesSocket ex:AM5 ;
    ex:hasTier ex:Advanced ;
    ex:hasCores 8 ;
    ex:hasThreads 16 .

ex:ryzen_7900x a ex:CPU ;
    ex:usesSocket ex:AM5 ;
    ex:hasTier ex:Premium ;
    ex:hasCores 12 ;
    ex:hasThreads 24 .

ex:Intel ex:manufactures ex:core_14100 .
ex:Intel ex:manufactures ex:core_14600k .
ex:Intel ex:manufactures ex:core_14700k .
ex:Intel ex:manufactures ex:core_14900k .

ex:AMD ex:manufactures ex:ryzen_7300x .
ex:AMD ex:manufactures ex:ryzen_7600x .
ex:AMD ex:manufactures ex:ryzen_7700x .
ex:AMD ex:manufactures ex:ryzen_7900x .

