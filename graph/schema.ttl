@prefix ex: <http://example.org/univ#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@prefix ex: <http://example.org/univ#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Component a owl:Class .
ex:Manufacturer a owl:Class .
ex:Tier a owl:Class .
ex:Socket a owl:Class .
ex:CPUFamily a owl:Class .


ex:CPU a owl:Class ;
    rdfs:subClassOf ex:Component .

ex:Motherboard a owl:Class ;
    rdfs:subClassOf ex:Component .

ex:usesSocket a owl:ObjectProperty ;
    rdfs:domain ex:CPU ;
    rdfs:range ex:Socket .

ex:hasSocket a owl:ObjectProperty ;
    rdfs:domain ex:Motherboard ;
    rdfs:range ex:Socket .

ex:manufactures a owl:ObjectProperty ;
    rdfs:domain ex:Manufacturer ;
    rdfs:range ex:Component .

ex:manufacturesFamily a owl:ObjectProperty ;
    rdfs:domain ex:Manufacturer ;
    rdfs:range ex:CPUFamily .

ex:hasTier a owl:ObjectProperty ;
    rdfs:domain ex:Component ;
    rdfs:range ex:Tier .

ex:hasCores a owl:DatatypeProperty ;
    rdfs:domain ex:CPU ;
    rdfs:range xsd:integer .

ex:hasThreads a owl:DatatypeProperty ;
    rdfs:domain ex:CPU ;
    rdfs:range xsd:integer .

ex:hasTDP a owl:DatatypeProperty ;
    rdfs:domain ex:Component ;
    rdfs:range xsd:integer .

ex:hasMaxPower a owl:DatatypeProperty ;
    rdfs:domain ex:Component ;
    rdfs:range xsd:integer .

ex:hasBaseClock a owl:DatatypeProperty ;
    rdfs:domain ex:CPU ;
    rdfs:range xsd:decimal .

ex:hasBoostClock a owl:DatatypeProperty ;
    rdfs:domain ex:CPU ;
    rdfs:range xsd:decimal .

ex:hasIntegratedGraphics a owl:DatatypeProperty ;
    rdfs:domain ex:CPU ;
    rdfs:range xsd:boolean .

ex:belongsToFamily a owl:ObjectProperty ;
    rdfs:domain ex:CPU ;
    rdfs:range ex:CPUFamily .
