    ex:supportsSocket ex:AM5 .

ex:X670 a ex:Chipset ;
    ex:supportsSocket ex:AM5 .

ex:X670E a ex:Chipset ;
    ex:supportsSocket ex:AM5 .

ex:B360 a ex:Chipset ;
    ex:supportsSocket ex:LGA1151_v2 .

ex:H370 a ex:Chipset ;
    ex:supportsSocket ex:LGA1151_v2 .

ex:Z370 a ex:Chipset ;
    ex:supportsSocket ex:LGA1151_v2 .

ex:Z390 a ex:Chipset ;
    ex:supportsSocket ex:LGA1151_v2 .

ex:H510 a ex:Chipset ;
    ex:supportsSocket ex:LGA1200 .

ex:B560 a ex:Chipset ;
