# ROG Matrix Boards (flagship, hybrid liquid-cooled)
ex:rog_matrix_rtx5090_asus a ex:GPUBoard ;
    rdfs:comment "Pode operar com BTF (GC-HPWR) ou 16-pin isoladamente; o pico de 800W (hasTDP) só é atingido usando ambos os conectores simultaneamente." ;
    ex:hasProductName "ROG Matrix RTX 5090 ASUS" ;
    ex:basedOnModel ex:rtx_5090_model ;
    ex:hasPCBBoard ex:asus_rog_matrix_pcb ;
    ex:hasPowerConnector ex:btf_connector , ex:pcie_16pin_connector ;
    ex:hasTier ex:HighEnd ;
    ex:hasArchitecture "Blackwell" ;
    ex:hasGPUCoreCount 16384 ;
    ex:hasGPUClock 2.6 ;
    ex:hasVRAMCapacity 24 ;
    ex:hasVRAMType "GDDR7" ;
    ex:hasVRAMClock 5440 ;
    ex:hasVRAMClockEffective 21760 ;
