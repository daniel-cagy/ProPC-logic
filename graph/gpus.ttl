# ========== PCB BOARDS (Placas) ==========

ex:asus_tuf_pcb a ex:PCBBoard ;
    rdfs:label "ASUS TUF PCB" ;
    rdfs:comment "ASUS TUF Series PCB Board" ;
    ex:manufacturedByComponent ex:ASUS ;
    ex:hasFormFactor "Dual Slot" .

ex:msi_ventus_pcb a ex:PCBBoard ;
    rdfs:label "MSI Ventus PCB" ;
    rdfs:comment "MSI Ventus Series PCB Board" ;
    ex:manufacturedByComponent ex:MSI ;
    ex:hasFormFactor "Dual Slot" .

ex:gigabyte_aorus_pcb a ex:PCBBoard ;
    rdfs:label "Gigabyte AORUS PCB" ;
    rdfs:comment "Gigabyte AORUS Series PCB Board" ;
    ex:manufacturedByComponent ex:Gigabyte ;
    ex:hasFormFactor "Dual Slot" .

ex:asus_rog_matrix_pcb a ex:PCBBoard ;
    rdfs:label "ASUS ROG Matrix PCB" ;
    rdfs:comment "ASUS ROG Matrix Series PCB Board (hybrid liquid-cooled flagship)" ;
    ex:manufacturedByComponent ex:ASUS ;
    ex:hasFormFactor "Dual Slot" .

ex:asus_rog_astral_pcb a ex:PCBBoard ;
    rdfs:label "ASUS ROG Astral PCB" ;
    rdfs:comment "ASUS ROG Astral Series PCB Board" ;
    ex:manufacturedByComponent ex:ASUS ;
    ex:hasFormFactor "Quad Slot" .

ex:asus_rog_astral_btf_pcb a ex:PCBBoard ;
    rdfs:label "ASUS ROG Astral BTF PCB" ;
    rdfs:comment "ASUS ROG Astral BTF Series PCB Board with rear (back-connector) power input" ;
    ex:manufacturedByComponent ex:ASUS ;
    ex:hasFormFactor "Quad Slot" .

# ========== GPU POWER CONNECTORS ==========

ex:btf_connector a ex:GPUConnector ;
    rdfs:label "ASUS BTF GC-HPWR Connector" ;
    rdfs:comment "ASUS Back-To-the-Future hidden power connector (GC-HPWR); requires a BTF-compatible motherboard." .

ex:pcie_16pin_connector a ex:GPUConnector ;
    rdfs:label "16-pin 12V-2x6 (12VHPWR) Connector" ;
    rdfs:comment "Standard PCIe 16-pin power connector." .

