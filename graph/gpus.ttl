# ========== GPU SERIES ==========

ex:rtx_20_series a ex:GPUSeries ;
    ex:hasSeriesName "RTX 20 Series" ;
    rdfs:label "NVIDIA GeForce RTX 20 Series" .

ex:rtx_30_series a ex:GPUSeries ;
    ex:hasSeriesName "RTX 30 Series" ;
    rdfs:label "NVIDIA GeForce RTX 30 Series" .

ex:rtx_40_series a ex:GPUSeries ;
    ex:hasSeriesName "RTX 40 Series" ;
    rdfs:label "NVIDIA GeForce RTX 40 Series" .

ex:rtx_50_series a ex:GPUSeries ;
    ex:hasSeriesName "RTX 50 Series" ;
    rdfs:label "NVIDIA GeForce RTX 50 Series" .

ex:radeon_6000_series a ex:GPUSeries ;
    ex:hasSeriesName "Radeon RX 6000 Series" ;
    rdfs:label "AMD Radeon RX 6000 Series" .

ex:radeon_7000_series a ex:GPUSeries ;
    ex:hasSeriesName "Radeon RX 7000 Series" ;
    rdfs:label "AMD Radeon RX 7000 Series" .

ex:radeon_9000_series a ex:GPUSeries ;
    ex:hasSeriesName "Radeon RX 9000 Series" ;
    rdfs:label "AMD Radeon RX 9000 Series" .

ex:arc_a_series a ex:GPUSeries ;
    ex:hasSeriesName "Arc A Series" ;
    rdfs:label "Intel Arc A Series" .

ex:arc_b_series a ex:GPUSeries ;
    ex:hasSeriesName "Arc B Series" ;
    rdfs:label "Intel Arc B Series" .

# ========== GPU MODELS ==========

# RTX 50 Series Models
ex:rtx_5090_model a ex:GPUModel ;
    ex:hasModelNumber "5090" ;
    ex:belongsToSeries ex:rtx_50_series ;
    ex:hasGraphicsChip ex:ga100_chip ;
    ex:hasGPUMemory ex:gddr7_24gb_memory_5090 ;
    ex:hasCores 16384 ;
    ex:hasGPUClock 2.6 ;
    ex:hasVRAMCapacity 24 ;
    ex:hasVRAMType "GDDR7" ;
    ex:hasVRAMClock 5440 ;
    ex:hasVRAMClockEffective 21760 ;
    ex:hasBusWidth 384 ;
    ex:hasTDP 520 ;
    ex:hasArchitecture "Blackwell" .

