# ========== GRAPHICS CHIPS (Processadores Gráficos) ==========

# NVIDIA Chips - RTX 50
ex:ga100_chip a ex:GraphicsChip ;
    rdfs:label "NVIDIA GA100" ;
    ex:hasGraphicsProcessorName "NVIDIA Blackwell GA100" ;
    ex:manufacturedByComponent ex:NVIDIA ;
    ex:hasCores 16384 .

ex:gb202_chip a ex:GraphicsChip ;
    rdfs:label "NVIDIA GB202" ;
    ex:hasGraphicsProcessorName "NVIDIA Blackwell GB202" ;
    ex:manufacturedByComponent ex:NVIDIA ;
    ex:hasCores 10752 .

ex:gb206_chip a ex:GraphicsChip ;
    rdfs:label "NVIDIA GB206" ;
    ex:hasGraphicsProcessorName "NVIDIA Blackwell GB206" ;
    ex:manufacturedByComponent ex:NVIDIA ;
    ex:hasCores 6144 .

ex:gb207_chip a ex:GraphicsChip ;
    rdfs:label "NVIDIA GB207" ;
    ex:hasGraphicsProcessorName "NVIDIA Blackwell GB207" ;
    ex:manufacturedByComponent ex:NVIDIA ;
